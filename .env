# =====================================================
# DATABASE URLs FOR EACH SERVICE
# =====================================================
# Separate Neon database per service.

# Auth Service Database
AUTH_DB_URL=jdbc:postgresql://${NEON_HOST}/agrilink_auth?sslmode=require&channel_binding=require&currentSchema=auth_schema
AUTH_DB_USER=${NEON_USERNAME}
AUTH_DB_PASSWORD=${NEON_PASSWORD}

# User Service Database  
USER_DB_URL=jdbc:postgresql://${NEON_HOST}/agrilink_user?sslmode=require&channel_binding=require&currentSchema=user_schema
USER_DB_USER=${NEON_USERNAME}
USER_DB_PASSWORD=${NEON_PASSWORD}

# Farm Service Database
FARM_DB_URL=jdbc:postgresql://${NEON_HOST}/agrilink_farm?sslmode=require&channel_binding=require&currentSchema=farm_schema
FARM_DB_USER=${NEON_USERNAME}
FARM_DB_PASSWORD=${NEON_PASSWORD}

# Marketplace Service Database
MARKETPLACE_DB_URL=jdbc:postgresql://${NEON_HOST}/agrilink_marketplace?sslmode=require&channel_binding=require&currentSchema=marketplace_schema
MARKETPLACE_DB_USER=${NEON_USERNAME}
MARKETPLACE_DB_PASSWORD=${NEON_PASSWORD}

# Order Service Database
ORDER_DB_URL=jdbc:postgresql://${NEON_HOST}/agrilink_order?sslmode=require&channel_binding=require&currentSchema=order_schema
ORDER_DB_USER=${NEON_USERNAME}
ORDER_DB_PASSWORD=${NEON_PASSWORD}

# Notification Service MongoDB
NOTIFICATION_MONGODB_URI=mongodb+srv://dbUser:dbUserPassword@cluster0.tr1obdu.mongodb.net/agrilink_notification?retryWrites=true&w=majority
NOTIFICATION_MONGODB_DATABASE=agrilink_notification

# =====================================================
# SPRING PROFILE
# =====================================================
SPRING_PROFILES_ACTIVE=neon